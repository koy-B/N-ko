generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CLIENT
  COLLECTOR
}

enum CollectionStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  address       String?
  city          String?
  password      String?
  role          Role      @default(CLIENT)
  points        Int       @default(0)
  level         String    @default("Eco Starter")
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  clientProfile      ClientProfile?
  collectorProfile   CollectorProfile?
  collectionRequests CollectionRequest[]
  assignments        CollectionAssignment[] @relation("AssignedCollector")
  orders             Order[]
  rewards            RewardHistory[]
  notifications      Notification[]
  auditLogs          AuditLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ClientProfile {
  id               String @id @default(cuid())
  userId           String @unique
  totalCollected   Float  @default(0)
  totalCollections Int    @default(0)
  totalSaved       Float  @default(0)
  badges           String @default("[]")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CollectorProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  latitude       Float?
  longitude      Float?
  isAvailable    Boolean  @default(true)
  totalEarned    Float    @default(0)
  totalCollected Float    @default(0)
  totalMissions  Int      @default(0)
  rating         Float    @default(0)
  vehicleType    String?
  serviceArea    String?
  lastActive     DateTime @default(now())

  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignments CollectionAssignment[]
}

model CollectionRequest {
  id              String           @id @default(cuid())
  clientId        String
  address         String
  latitude        Float?
  longitude       Float?
  wasteType       String
  estimatedWeight Float
  photos          String           @default("[]")
  comment         String?
  status          CollectionStatus @default(PENDING)
  scheduledDate   DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  client      User                   @relation(fields: [clientId], references: [id])
  assignments CollectionAssignment[]
}

model CollectionAssignment {
  id              String           @id @default(cuid())
  collectionId    String
  collectorId     String
  startedAt       DateTime?
  completedAt     DateTime?
  status          CollectionStatus @default(ASSIGNED)
  photoProof      String?
  actualWeight    Float?
  clientSignature String?
  notes           String?
  createdAt       DateTime         @default(now())

  collection         CollectionRequest @relation(fields: [collectionId], references: [id])
  collector          User              @relation("AssignedCollector", fields: [collectorId], references: [id])
  collectorProfile   CollectorProfile? @relation(fields: [collectorProfileId], references: [id])
  collectorProfileId String?
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  price       Float
  categoryId  String
  images      String   @default("[]")
  stock       Int      @default(0)
  weight      Float?
  dimensions  String?
  colors      String   @default("[]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category          Category           @relation(fields: [categoryId], references: [id])
  orderItems        OrderItem[]
  productionOutputs ProductionOutput[]
}

model Category {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  products Product[]
}

model Order {
  id            String        @id @default(cuid())
  userId        String
  total         Float
  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  address       String
  phone         String?
  notes         String?
  invoiceUrl    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user     User        @relation(fields: [userId], references: [id])
  items    OrderItem[]
  payments Payment[]
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model Payment {
  id        String        @id @default(cuid())
  orderId   String
  amount    Float
  method    String
  status    PaymentStatus @default(PENDING)
  reference String?
  createdAt DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

model Reward {
  id          String   @id @default(cuid())
  name        String
  description String?
  pointsCost  Int
  type        String
  value       Float?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  redemptions RewardHistory[]
}

model RewardHistory {
  id         String   @id @default(cuid())
  userId     String
  rewardId   String
  pointsUsed Int
  createdAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  reward Reward @relation(fields: [rewardId], references: [id])
}

model PlasticStock {
  id         String   @id @default(cuid())
  weight     Float
  source     String
  quality    String
  notes      String?
  receivedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  productionBatches ProductionBatch[]
}

model ProductionBatch {
  id             String    @id @default(cuid())
  name           String
  plasticStockId String
  plasticUsed    Float
  bricksProduced Int
  cost           Float
  revenue        Float
  status         String    @default("IN_PROGRESS")
  startedAt      DateTime  @default(now())
  completedAt    DateTime?
  notes          String?
  createdAt      DateTime  @default(now())

  plasticStock PlasticStock       @relation(fields: [plasticStockId], references: [id])
  outputs      ProductionOutput[]
}

model ProductionOutput {
  id        String   @id @default(cuid())
  batchId   String
  productId String
  quantity  Int
  weight    Float
  createdAt DateTime @default(now())

  batch   ProductionBatch @relation(fields: [batchId], references: [id])
  product Product         @relation(fields: [productId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  details   String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String?
  content   String
  image     String?
  author    String
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}
